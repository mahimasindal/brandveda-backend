# App
PORT=3000
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/brand-veda

# JWT
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# LLM Router — set USE_OPENROUTER=true to route all providers through OpenRouter
# (uses gpt-4o-mini, gemini-2.0-flash-001, perplexity/sonar — ~10x cheaper than direct GPT-4o)
USE_OPENROUTER=false

# LLM Enable/Disable (set to false to skip a provider entirely)
OPENAI_ENABLED=true
PERPLEXITY_ENABLED=true
GEMINI_ENABLED=true

# LLM Burst Rate Limits (calls per second per provider)
OPENAI_BURST_SIZE=5
PERPLEXITY_BURST_SIZE=5
GEMINI_BURST_SIZE=5

# OpenAI
OPENAI_API_KEY=sk-...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter (single key for all providers — used when USE_OPENROUTER=true)
OPENROUTER_API_KEY=sk-or-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
